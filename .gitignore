# ── Environment (secrets — never commit) ──────────────────────────────────────
.env
*.env.local
.env.*
!.env.example

# ── Database (real user data — never commit) ──────────────────────────────────
*.db
*.db-journal        # SQLite WAL journal — generated automatically, not code
*.db-shm            # SQLite shared memory file
*.db-wal            # SQLite WAL file
*.db-backup
*.sqlite
data/               # Docker volume mount (contains live DB + backups)

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python
venv/
env/
.venv/
*.egg-info/
dist/
build/
.eggs/

# ── Legacy / replaced files ───────────────────────────────────────────────────
ollama_client.py    # Replaced by local_ai.py (LM Studio + Ollama + Claude Vision)

# ── Explicit file exclusions (belt-and-suspenders alongside glob patterns) ────
expenses.db-journal # SQLite WAL journal for expenses.db

# ── Editor / tool local config (machine-specific, not project code) ───────────
.claude/
.idea/
.vscode/
*.swp
*.swo

# ── SSL certificates ──────────────────────────────────────────────────────────
nginx/ssl/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Docker ────────────────────────────────────────────────────────────────────
.dockerignore

# ── Monitoring runtime data (Docker volumes — not config) ─────────────────────
monitoring/grafana/data/
monitoring/prometheus/data/
monitoring/loki/data/
