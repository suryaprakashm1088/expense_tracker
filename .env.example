# ─────────────────────────────────────────────────────────────────────────────
# Expense Tracker — Environment Variables
# Copy this file to .env and fill in real values.  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Twilio (required for WhatsApp bot) ────────────────────────────────────────
# Find these at: https://console.twilio.com → home page
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Twilio WhatsApp number (sandbox: +14155238886, paid: your assigned number)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── Anthropic Claude (optional — enables receipt scanning + daily AI summary) ──
# Get key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=production

# Generate with: python3 -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=change-me-generate-a-real-secret-key

# ── App URL ───────────────────────────────────────────────────────────────────
# The public URL of your app (used in WhatsApp bot links)
# ngrok:       DASHBOARD_URL=https://abc123.ngrok-free.app
# Cloudflare:  DASHBOARD_URL=https://yourdomain.com
DASHBOARD_URL=https://yourdomain.com

# ── Cloudflare Tunnel (only needed for Cloudflare deployment) ─────────────────
# Get from: Zero Trust dashboard → Networks → Tunnels → your tunnel → Docker tab
# CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoiZ...

# ── Database path (set automatically by docker-compose — do not change) ────────
# DB_PATH=/data/expenses.db

# ── Backup retention ──────────────────────────────────────────────────────────
# Number of daily backups to keep before the oldest is deleted.
# Default: 30  |  Minimum recommended: 7
# BACKUP_KEEP_DAYS=30

# ── Investments — EODHD (global + Indian stock prices) ───────────────────────
# Get a free API key at: https://eodhd.com → Register → API Tokens
# Free tier: 20 API calls/day — sufficient for a personal portfolio of <20 stocks
# Leave blank to disable stock price fetching (manual prices only)
# EODHD_API_KEY=demo

# Hour (UTC) at which the daily price refresh runs automatically.
# Default 9 UTC = 17:00 SGT (after Indian market closes at 15:30 IST = 10:00 UTC)
# INVESTMENT_REFRESH_HOUR=9

# ── Monitoring — Grafana ──────────────────────────────────────────────────────
# Password for the Grafana admin account at http://localhost:3000
# Change this to something strong — it's used by monitoring/docker-compose.monitoring.yml
GRAFANA_ADMIN_PASSWORD=your-grafana-password-here

# ── AI Vision — LM Studio (primary, local, runs on Mac) ───────────────────────
# Download LM Studio: https://lmstudio.ai  →  Local Server tab  →  Start Server
# Load a vision model first, e.g. qwen3-vl-4b or llava-1.5-7b
# These defaults are set in docker-compose.local.yml; override here if needed.
# LM_STUDIO_URL=http://host.docker.internal:1234/v1
# LM_STUDIO_VISION_MODEL=qwen3-vl-4b

# ── AI Vision — Ollama (fallback, local Metal GPU on Mac) ─────────────────────
# Install: https://ollama.com  |  Start: ollama serve  |  Pull: ollama pull llava
# OLLAMA_URL=http://host.docker.internal:11434
# OLLAMA_VISION=llava:7b

# ── AI Text — Docker Model Runner (optional, built into Docker Desktop) ────────
# Enable: docker desktop → Settings → Features in development → Enable Model Runner
# Pull:   docker model pull ai/llama3.2
# MODEL_RUNNER_URL=http://host.docker.internal:12434/engines/llama.cpp/v1
# DMR_TEXT_MODEL=docker.io/ai/llama3.2:latest
