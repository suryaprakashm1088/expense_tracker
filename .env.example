# ─────────────────────────────────────────────────────────────────────────────
# Expense Tracker — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Twilio WhatsApp ───────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+1415XXXXXXX

# ── Anthropic Claude (for receipt AI parsing) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ── App Config ────────────────────────────────────────────────────────────────
FLASK_ENV=production
# Generate with: python3 -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=change-this-to-random-string-min-32-chars
# Your domain (used in WhatsApp invite links and notifications)
DASHBOARD_URL=https://yourdomain.com

# ── Database ──────────────────────────────────────────────────────────────────
# Docker maps ./data on host to /data in container
DB_PATH=/data/expenses.db
